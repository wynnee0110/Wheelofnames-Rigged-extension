{
  "manifest_version": 3,
  "name": "Wheel of Names Rigger",
  "version": "2.0",
  "description": "Force Wheel of Names to land on your chosen target every time",
  "permissions": [
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "*://wheelofnames.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://wheelofnames.com/*"
      ],
      "js": [
        "inject-bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://wheelofnames.com/*"
      ],
      "js": [
        "panel.js"
      ],
      "run_at": "document_idle",
      "css": [
        "panel.css"
      ]
    }
  ]
}